{
  "name": "dess2-bogaloo (py3.12-trixie + uv)",
  "image": "ghcr.io/astral-sh/uv:python3.12-trixie",
  "runArgs": ["--gpus=device=7"],

  "customizations": {
    "vscode": {
      "extensions": [
        "OpenAI.chatgpt",
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },

  "postCreateCommand": "uv sync --locked || uv sync"
}
